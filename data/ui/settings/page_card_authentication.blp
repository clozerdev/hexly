using Gtk 4.0;
using Adw 1;

template $HexlySettingsPageAuthentication: Adw.PreferencesPage {
  name: "card-authentication";
  title: _("Card Authentication");
  icon-name: "code-symbolic";

  Adw.PreferencesGroup {
    title: _("Card");

    Adw.SwitchRow {
      title: _("Use default MIFARE authentication keys");
      action-name: "widget.default-auth-keys";
    }
  }
}
